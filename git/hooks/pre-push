#!/usr/bin/env bash
# Global pre-push hook (core.hooksPath).
# Delegates to a repo-local hook at <repo>/.githooks/pre-push if present.
# Otherwise exits silently — do not block pushes in repos that don't opt in.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
[ -n "$REPO_ROOT" ] || exit 0

LOCAL_HOOK="$REPO_ROOT/.githooks/pre-push"
[ -x "$LOCAL_HOOK" ] || exit 0

exec "$LOCAL_HOOK" "$@"

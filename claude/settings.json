{
  "permissions": {
    "allow": [
      "Read:~/.davinci-mcp/**",
      "mcp__mermaid__generate_mermaid_diagram"
    ],
    "deny": [
      "Bash(keeper*)"
    ],
    "unsupervisedTools": [
      "Edit",
      "MultiEdit",
      "Write",
      "Bash",
      "Read",
      "Glob",
      "Grep"
    ],
    "allowedCommands": [
      "git",
      "gh",
      "npm test",
      "python",
      "node",
      "pytest"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/custom-reminder.py"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'if (name of (info for (path to frontmost application))) is not \"Ghostty.app\" then display notification \"Claude needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'if (name of (info for (path to frontmost application))) is not \"Ghostty.app\" then display notification \"Response complete\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true,
  "mcpServers": {
    "email": {
      "command": "~/.claude/mcp-wrappers/email-mcp",
      "type": "stdio"
    },
    "whoop": {
      "command": "uv",
      "args": [
        "run", "--frozen",
        "--directory", "~/projects/mcp/whoop-mcp",
        "start"
      ]
    },
    "hevy": {
      "command": "npx",
      "args": ["-y", "@chrisdoc/hevy-mcp"]
    }
  },
  "feedbackSurveyState": {
    "lastShownTime": 1755134822529
  },
  "defaultOutputStyle": "sr-software-developer",
  "preferredNotifChannel": "iterm2"
}

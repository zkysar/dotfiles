#!/usr/bin/env bash
# Reads HEVY_API_KEY from macOS Keychain (synced there by bin/keys) and
# passes it to hevy-mcp via the environment. This avoids putting the key
# in settings.json while still working when Claude Code isn't launched
# from a shell that has the full zshrc environment loaded.
set -euo pipefail

HEVY_API_KEY=$(security find-generic-password -s HEVY_API_KEY -a "$USER" -w)
export HEVY_API_KEY

# Pin npm version — bumps must be intentional (wrapper runs with secrets in env).
exec npx -y hevy-mcp@1.23.6

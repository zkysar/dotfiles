#!/usr/bin/env bash
# Wrapper for codefuturist/email-mcp — reads credentials from Keychain
# so settings.json stays credential-free.
set -euo pipefail

MCP_EMAIL_ADDRESS="zachkysar.claude@gmail.com"
MCP_EMAIL_PASSWORD=$(security find-generic-password -s CLAUDE_GMAIL_APP_PASSWORD -a "$USER" -w)
MCP_EMAIL_IMAP_HOST="imap.gmail.com"
MCP_EMAIL_SMTP_HOST="smtp.gmail.com"

export MCP_EMAIL_ADDRESS MCP_EMAIL_PASSWORD MCP_EMAIL_IMAP_HOST MCP_EMAIL_SMTP_HOST

exec npx -y email-mcp

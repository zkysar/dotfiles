# Machine-specific Claude settings
claude/settings.local.json

# Project-level Claude Code runtime directory (session state, local settings)
.claude/

# Hook secrets (.env pattern already used by pushover-notification.py)
claude/hooks/.env

# Claude runtime noise that lands inside symlinked dirs
claude/**/cache/
claude/**/*.cache
claude/**/*.log

# Editor/OS noise
.DS_Store
nvim/.netrwhist
nvim/lazy-lock.json

# Backups created by bin/link (stored at $HOME, not in repo, but guard anyway)
.dotfiles-backup/

# gcalcli OAuth token (written by gcalcli into the tracked config dir)
claude/gcalcli/oauth2.json

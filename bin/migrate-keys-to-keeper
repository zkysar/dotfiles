#!/usr/bin/env bash
# One-shot migration: reads ~/.keys.sh and creates Keeper records with env-var-style titles.
# Run in your own terminal (Claude is denied from invoking 'keeper').
#
# Usage:
#   bin/migrate-keys-to-keeper            # dry run — prints what would happen
#   bin/migrate-keys-to-keeper --execute  # actually create records
#   bin/migrate-keys-to-keeper --execute --only TODOIST_API_TOKEN  # just one
#
# After it succeeds, run 'bin/keys sync' to pull into Keychain, then 'rm ~/.keys.sh'.
set -euo pipefail

KEYS_FILE="$HOME/.keys.sh"
FOLDER="env-vars"
RECORD_TYPE="login"
EXECUTE=0
ONLY=""

while [ $# -gt 0 ]; do
  case "$1" in
    --execute) EXECUTE=1; shift ;;
    --only)    ONLY="$2"; shift 2 ;;
    --file)    KEYS_FILE="$2"; shift 2 ;;
    -h|--help)
      sed -n '3,13p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

[ -f "$KEYS_FILE" ] || { echo "error: $KEYS_FILE not found" >&2; exit 1; }
command -v keeper >/dev/null || { echo "error: keepercommander not installed" >&2; exit 1; }

if [ "$EXECUTE" = 0 ]; then
  echo "== DRY RUN (pass --execute to actually create records) =="
fi
echo ""

added=0; skipped=0; failed=0
while IFS= read -r line; do
  [[ "$line" =~ ^[[:space:]]*# ]] && continue
  [[ -z "${line// /}" ]] && continue

  if [[ "$line" =~ ^[[:space:]]*export[[:space:]]+([A-Z][A-Z0-9_]*)=(.*)$ ]]; then
    name="${BASH_REMATCH[1]}"
    raw="${BASH_REMATCH[2]}"
    # Strip optional surrounding double or single quotes
    if   [[ "$raw" =~ ^\"(.*)\"$ ]]; then value="${BASH_REMATCH[1]}"
    elif [[ "$raw" =~ ^\'(.*)\'$ ]]; then value="${BASH_REMATCH[1]}"
    else                                    value="$raw"
    fi

    if [ -n "$ONLY" ] && [ "$name" != "$ONLY" ]; then
      continue
    fi

    if [ -z "$value" ]; then
      echo "⚠ skip $name (empty value)"
      skipped=$((skipped+1))
      continue
    fi

    if [ "$EXECUTE" = 0 ]; then
      echo "would add: $name  (value length: ${#value})"
      continue
    fi

    echo "→ adding $name"
    # Note: 'password=VALUE' field-notation is a guess pending --syntax-help.
    # If this fails, adjust the field spec below (e.g. 'f.password=' or 'password.value=').
    if keeper record-add -t "$name" -rt "$RECORD_TYPE" --folder "$FOLDER" "password=$value"; then
      added=$((added+1))
    else
      echo "✗ failed to add $name" >&2
      failed=$((failed+1))
    fi
  fi
done < "$KEYS_FILE"

echo ""
if [ "$EXECUTE" = 0 ]; then
  echo "Dry run complete. Re-run with --execute to create records."
else
  echo "Added $added, skipped $skipped, failed $failed"
  echo ""
  echo "Next:"
  echo "  bin/keys sync          # pull into Keychain"
  echo "  bin/keys list          # verify"
  echo "  rm $KEYS_FILE          # only after confirming sync worked"
fi

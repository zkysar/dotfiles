#!/usr/bin/env bash
# Create/verify symlinks per manifest.toml.
# - already-correct symlink: skip
# - dest missing:            create
# - dest is a real file/dir: move to ~/.dotfiles-backup/<ts>/ then link
# - dest is a symlink elsewhere: warn (require --force to overwrite)
# After linking, prunes orphan symlinks: any symlink in a manifest parent dir
# whose target points into this repo but is not listed in the manifest.
# Before linking, sweeps ~/.dotfiles-backup/ entries older than 30 days
# (non-fatal — pruning errors don't abort the run).
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$REPO_ROOT/bin"
MANIFEST="$REPO_ROOT/manifest.toml"
BACKUP_ROOT="$HOME/.dotfiles-backup/$(date -u +%Y%m%dT%H%M%SZ)"
FORCE=0
[ "${1:-}" = "--force" ] && FORCE=1

[ -f "$MANIFEST" ] || { echo "error: manifest.toml not found" >&2; exit 1; }

# Sweep ~/.dotfiles-backup/ entries older than 30 days. Non-fatal.
"$BIN_DIR/_prune-backups" || true

parse_manifest() {
  awk '
    /^\[\[link\]\]/ { in_link=1; src=""; dest=""; next }
    in_link && /^src[[:space:]]*=/  { match($0, /"[^"]*"/); src  = substr($0, RSTART+1, RLENGTH-2) }
    in_link && /^dest[[:space:]]*=/ {
      match($0, /"[^"]*"/); dest = substr($0, RSTART+1, RLENGTH-2)
      if (src != "" && dest != "") print src "\t" dest
      in_link=0
    }
  ' "$MANIFEST"
}

expand_home() {
  case "$1" in
    "~/"*) echo "$HOME/${1:2}" ;;
    *)     echo "$1" ;;
  esac
}

linked=0; skipped=0; backed_up=0; warned=0; pruned=0
# Track whether we touched any zsh completion file (basename `_*`). If so, the
# .zcompdump cache is stale and must be wiped — compinit's own staleness check
# is unreliable in practice, leaving new completions invisible until the cache
# happens to roll over. Wiping forces compinit to rebuild on next shell start.
comp_changed=0
is_completion() {
  case "$(basename "$1")" in _*) return 0 ;; *) return 1 ;; esac
}

EXPECTED_FILE="$(mktemp)"
PARENTS_FILE="$(mktemp)"
trap 'rm -f "$EXPECTED_FILE" "$PARENTS_FILE"' EXIT

while IFS=$'\t' read -r src dest; do
  [ -z "$src" ] && continue
  case "$src" in
    "~/"*) src_abs="$(expand_home "$src")" ;;
    /*)    src_abs="$src" ;;
    *)     src_abs="$REPO_ROOT/$src" ;;
  esac
  dest_abs="$(expand_home "$dest")"

  echo "$dest_abs" >> "$EXPECTED_FILE"
  dirname "$dest_abs" >> "$PARENTS_FILE"

  if [ ! -e "$src_abs" ] && [ ! -L "$src_abs" ]; then
    echo "✗ source missing in repo: $src" >&2
    warned=$((warned+1))
    continue
  fi

  mkdir -p "$(dirname "$dest_abs")"

  if [ -L "$dest_abs" ]; then
    current="$(readlink "$dest_abs")"
    if [ "$current" = "$src_abs" ]; then
      echo "✓ $dest"
      skipped=$((skipped+1))
      continue
    fi
    if [ "$FORCE" = 1 ]; then
      rm "$dest_abs"
      ln -s "$src_abs" "$dest_abs"
      echo "→ replaced: $dest"
      linked=$((linked+1))
      is_completion "$dest_abs" && comp_changed=1
    else
      echo "⚠ $dest → $current (use --force to overwrite)" >&2
      warned=$((warned+1))
    fi
    continue
  fi

  if [ -e "$dest_abs" ]; then
    rel="${dest_abs#$HOME/}"
    backup_target="$BACKUP_ROOT/$rel"
    mkdir -p "$(dirname "$backup_target")"
    mv "$dest_abs" "$backup_target"
    echo "→ backed up: $dest_abs → $backup_target"
    backed_up=$((backed_up+1))
  fi

  ln -s "$src_abs" "$dest_abs"
  echo "→ linked: $dest"
  linked=$((linked+1))
  is_completion "$dest_abs" && comp_changed=1
done < <(parse_manifest)

# Prune orphans: symlinks in manifest parent dirs whose target points into
# REPO_ROOT but which are not listed as expected destinations.
while IFS= read -r parent; do
  [ -d "$parent" ] || continue
  while IFS= read -r -d '' link; do
    target="$(readlink "$link")"
    case "$target" in
      "$REPO_ROOT"/*)
        if ! grep -Fxq "$link" "$EXPECTED_FILE"; then
          rm "$link"
          rel="${link#$HOME/}"
          if [ "$rel" != "$link" ]; then
            echo "→ pruned orphan: ~/$rel"
          else
            echo "→ pruned orphan: $link"
          fi
          pruned=$((pruned+1))
          is_completion "$link" && comp_changed=1
        fi
        ;;
    esac
  done < <(find "$parent" -maxdepth 1 -type l -print0 2>/dev/null)
done < <(sort -u "$PARENTS_FILE")

if [ "$comp_changed" = 1 ]; then
  # Glob may not match; don't fail the run if there's nothing to remove.
  rm -f "$HOME"/.zcompdump* 2>/dev/null || true
  echo "→ wiped ~/.zcompdump* (zsh completion changed; rebuild on next shell start)"
fi

echo ""
echo "Summary: $linked linked, $skipped already correct, $backed_up backed up, $pruned pruned, $warned warnings"

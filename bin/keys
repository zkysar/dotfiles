#!/usr/bin/env bash
# Keeper → Keychain one-way sync (Option 2: Keeper is source of truth).
#
# Convention: records inside the `ENV_FOLDER` folder in Keeper whose title
# matches `TITLE_REGEX` are treated as env vars. Each record's password
# field is mirrored to a macOS Keychain entry with the record title as the
# service name. zshrc iterates the names file at shell start and exports
# each present Keychain entry.
#
# Adjust ENV_FOLDER below if you rename the folder in Keeper.
#
# Subcommands: list, sync, rm
set -euo pipefail

NAMES_FILE="$HOME/.dotfiles-keychain-names"
ENV_FOLDER="env-vars"
TITLE_REGEX='^[A-Z][A-Z0-9_]+$'

cmd="${1:-}"
case "$cmd" in
  list)
    if [ ! -f "$NAMES_FILE" ]; then
      echo "No names list yet. Run 'bin/keys sync' to populate." >&2
      exit 0
    fi
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      if security find-generic-password -s "$name" -a "$USER" -w >/dev/null 2>&1; then
        printf '%-30s present\n' "$name"
      else
        printf '%-30s MISSING\n' "$name"
      fi
    done < "$NAMES_FILE"
    ;;

  sync)
    if ! command -v keeper >/dev/null 2>&1; then
      echo "error: keepercommander not installed. Run bin/bootstrap first." >&2
      exit 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
      echo "error: jq not installed. Run bin/bootstrap first." >&2
      exit 1
    fi
    # Scope to records inside ENV_FOLDER. Output shape: [{type, uid, name, details}, ...].
    listing=$(keeper ls "$ENV_FOLDER" --format=json 2>/dev/null)
    if [ -z "$listing" ]; then
      echo "error: 'keeper ls $ENV_FOLDER' returned nothing — folder missing, empty, or not logged in?" >&2
      echo "Check 'keeper login' and that a folder named '$ENV_FOLDER' exists with records in it." >&2
      exit 1
    fi
    # Only records (not subfolders) whose name matches the env-var regex.
    records=$(printf '%s' "$listing" | jq -c --arg re "$TITLE_REGEX" \
      '.[] | select(.type == "record" and (.name | test($re)))')
    if [ -z "$records" ]; then
      echo "No env-var-style records in '$ENV_FOLDER'." >&2
      exit 0
    fi
    # De-dupe first (sequential, cheap). Collect unique (title, uid) pairs.
    seen_tmp=$(mktemp)
    work=()
    skipped_dupe=0
    while IFS= read -r rec; do
      [ -z "$rec" ] && continue
      title=$(printf '%s' "$rec" | jq -r '.name')
      uid=$(printf   '%s' "$rec" | jq -r '.uid')
      if grep -Fxq "$title" "$seen_tmp" 2>/dev/null; then
        echo "⚠ $title: duplicate record in '$ENV_FOLDER' (keeping first)" >&2
        skipped_dupe=$((skipped_dupe+1))
        continue
      fi
      printf '%s\n' "$title" >> "$seen_tmp"
      work+=("$title"$'\t'"$uid")
    done <<< "$records"
    rm -f "$seen_tmp"

    # Parallel fetch: one background job per record. For each, fetch detail,
    # extract password, write to Keychain, record outcome to a per-job file
    # so aggregation is race-free.
    results_dir=$(mktemp -d)
    trap "rm -rf '$results_dir'" EXIT
    for i in "${!work[@]}"; do
      IFS=$'\t' read -r title uid <<< "${work[$i]}"
      (
        detail=$(keeper get "$uid" --format=json 2>/dev/null || true)
        if [ -z "$detail" ]; then
          printf 'FAIL\tno_detail\t%s\n' "$title" > "$results_dir/$i"
          exit 0
        fi
        val=$(printf '%s' "$detail" | jq -r '.password // empty')
        if [ -z "$val" ]; then
          val=$(printf '%s' "$detail" \
            | jq -r '(.fields // []) | map(select(.type == "password" or .type == "secret")) | .[0].value[0] // empty')
        fi
        if [ -z "$val" ]; then
          printf 'FAIL\tno_password\t%s\n' "$title" > "$results_dir/$i"
          exit 0
        fi
        security add-generic-password -U -s "$title" -a "$USER" -w "$val"
        printf 'OK\t%s\n' "$title" > "$results_dir/$i"
      ) &
    done
    wait

    # Aggregate — iterate by original index to keep output order stable.
    fetched=0; failed=0
    names_tmp=$(mktemp)
    for i in "${!work[@]}"; do
      line=$(cat "$results_dir/$i" 2>/dev/null || echo "FAIL	no_result	unknown")
      case "${line%%$'\t'*}" in
        OK)
          title="${line#OK$'\t'}"
          echo "✓ $title"
          printf '%s\n' "$title" >> "$names_tmp"
          fetched=$((fetched+1))
          ;;
        FAIL)
          rest="${line#FAIL$'\t'}"
          reason="${rest%%$'\t'*}"
          title="${rest#*$'\t'}"
          echo "✗ $title: $reason" >&2
          failed=$((failed+1))
          ;;
      esac
    done
    mv "$names_tmp" "$NAMES_FILE"
    echo ""
    echo "Synced $fetched to Keychain (skipped $skipped_dupe dupes, $failed failed). ${#work[@]} records processed in parallel."
    ;;

  rm)
    name="${2:-}"
    if [ -z "$name" ]; then echo "usage: keys rm <NAME>" >&2; exit 1; fi
    if security delete-generic-password -s "$name" -a "$USER" >/dev/null 2>&1; then
      echo "✓ removed $name from Keychain"
    else
      echo "⚠ $name not in Keychain"
    fi
    if [ -f "$NAMES_FILE" ]; then
      tmp=$(mktemp)
      grep -v "^$name$" "$NAMES_FILE" > "$tmp" || true
      mv "$tmp" "$NAMES_FILE"
    fi
    echo "Note: Keeper record untouched — delete manually in Keeper if desired."
    ;;

  *)
    cat >&2 <<EOF
usage: keys <command>

  list        show each env-var in the names list (present|MISSING in Keychain)
  sync        pull every ENV_VAR_STYLE-titled Keeper record into Keychain
  rm NAME     remove from Keychain (Keeper record untouched)

Adding a key: create a record in Keeper with an env-var-style title
(e.g., TODOIST_API_TOKEN) and put the value in the password field.
Then run 'bin/keys sync'. No local manifest to edit.
EOF
    exit 1
    ;;
esac

#!/usr/bin/env bash
# Keeper → Keychain one-way sync (Option 2: Keeper is source of truth).
#
# Convention: any Keeper record whose title matches ENV_VAR_STYLE
# (^[A-Z][A-Z0-9_]+$) is treated as an env var. Its 'password' field
# becomes the value. Run 'bin/keys sync' after adding/editing records
# in Keeper to refresh Keychain and the names list.
#
# Subcommands: list, sync, rm
set -euo pipefail

NAMES_FILE="$HOME/.dotfiles-keychain-names"
TITLE_REGEX='^[A-Z][A-Z0-9_]+$'

cmd="${1:-}"
case "$cmd" in
  list)
    if [ ! -f "$NAMES_FILE" ]; then
      echo "No names list yet. Run 'bin/keys sync' to populate." >&2
      exit 0
    fi
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      if security find-generic-password -s "$name" -a "$USER" -w >/dev/null 2>&1; then
        printf '%-30s present\n' "$name"
      else
        printf '%-30s MISSING\n' "$name"
      fi
    done < "$NAMES_FILE"
    ;;

  sync)
    if ! command -v keeper >/dev/null 2>&1; then
      echo "error: keepercommander not installed. Run bin/bootstrap first." >&2
      exit 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
      echo "error: jq not installed. Run bin/bootstrap first." >&2
      exit 1
    fi
    listing=$(keeper list --format=json 2>/dev/null)
    if [ -z "$listing" ]; then
      echo "error: 'keeper list' returned no output — are you logged in? Run 'keeper login'." >&2
      exit 1
    fi
    # Records whose title matches ENV_VAR_STYLE.
    records=$(printf '%s' "$listing" | jq -c --arg re "$TITLE_REGEX" \
      '.[] | select(.title | test($re))')
    if [ -z "$records" ]; then
      echo "No records with env-var-style titles found in Keeper." >&2
      echo "Create records with titles like MY_API_KEY and put the value in the password field." >&2
      exit 0
    fi
    fetched=0; failed=0
    names_tmp=$(mktemp)
    while IFS= read -r rec; do
      [ -z "$rec" ] && continue
      title=$(printf '%s' "$rec" | jq -r '.title')
      uid=$(printf '%s'   "$rec" | jq -r '.record_uid')
      detail=$(keeper get "$uid" --format=json 2>/dev/null || true)
      if [ -z "$detail" ]; then
        echo "✗ $title: could not fetch record detail" >&2
        failed=$((failed+1))
        continue
      fi
      val=$(printf '%s' "$detail" | jq -r '.password // empty')
      if [ -z "$val" ]; then
        val=$(printf '%s' "$detail" \
          | jq -r '(.fields // []) | map(select(.type == "password" or .type == "secret")) | .[0].value[0] // empty')
      fi
      if [ -z "$val" ]; then
        echo "✗ $title: record has no password/secret field" >&2
        failed=$((failed+1))
        continue
      fi
      security add-generic-password -U -s "$title" -a "$USER" -w "$val"
      printf '%s\n' "$title" >> "$names_tmp"
      echo "✓ $title"
      fetched=$((fetched+1))
    done <<< "$records"
    mv "$names_tmp" "$NAMES_FILE"
    echo ""
    echo "Synced $fetched to Keychain, failed $failed. Names tracked in $NAMES_FILE"
    ;;

  rm)
    name="${2:-}"
    if [ -z "$name" ]; then echo "usage: keys rm <NAME>" >&2; exit 1; fi
    if security delete-generic-password -s "$name" -a "$USER" >/dev/null 2>&1; then
      echo "✓ removed $name from Keychain"
    else
      echo "⚠ $name not in Keychain"
    fi
    if [ -f "$NAMES_FILE" ]; then
      tmp=$(mktemp)
      grep -v "^$name$" "$NAMES_FILE" > "$tmp" || true
      mv "$tmp" "$NAMES_FILE"
    fi
    echo "Note: Keeper record untouched — delete manually in Keeper if desired."
    ;;

  *)
    cat >&2 <<EOF
usage: keys <command>

  list        show each env-var in the names list (present|MISSING in Keychain)
  sync        pull every ENV_VAR_STYLE-titled Keeper record into Keychain
  rm NAME     remove from Keychain (Keeper record untouched)

Adding a key: create a record in Keeper with an env-var-style title
(e.g., TODOIST_API_TOKEN) and put the value in the password field.
Then run 'bin/keys sync'. No local manifest to edit.
EOF
    exit 1
    ;;
esac

#!/usr/bin/env bash
# Keeper → Keychain one-way sync (Option 2: Keeper is source of truth).
#
# Convention: records inside the `ENV_FOLDER` folder in Keeper whose title
# matches `TITLE_REGEX` are treated as env vars. Each record's password
# field is mirrored to a macOS Keychain entry with the record title as the
# service name. zshrc iterates the names file at shell start and exports
# each present Keychain entry.
#
# Adjust ENV_FOLDER below if you rename the folder in Keeper.
#
# Subcommands: list, sync, rm
set -euo pipefail

NAMES_FILE="$HOME/.dotfiles-keychain-names"
ENV_FOLDER="env-vars"
TITLE_REGEX='^[A-Z][A-Z0-9_]+$'

cmd="${1:-}"
case "$cmd" in
  list)
    if [ ! -f "$NAMES_FILE" ]; then
      echo "No names list yet. Run 'dots keys sync' to populate." >&2
      exit 0
    fi
    while IFS= read -r name; do
      [ -z "$name" ] && continue
      if security find-generic-password -s "$name" -a "$USER" -w >/dev/null 2>&1; then
        printf '%-30s present\n' "$name"
      else
        printf '%-30s MISSING\n' "$name"
      fi
    done < "$NAMES_FILE"
    ;;

  sync)
    if ! command -v keeper >/dev/null 2>&1; then
      echo "error: keepercommander not installed. Run dots bootstrap first." >&2
      exit 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
      echo "error: jq not installed. Run dots bootstrap first." >&2
      exit 1
    fi

    # Single keeper call: export the ENV_FOLDER folder as JSON to stdout
    # (omitting the positional filename = console output).
    # --force suppresses any interactive confirmation.
    raw=$(keeper export --folder "$ENV_FOLDER" --format=json --force 2>&1)

    if [ -z "$raw" ]; then
      echo "error: 'keeper export --folder $ENV_FOLDER' returned nothing." >&2
      exit 1
    fi

    # Strip anything before the first line starting with '[' or '{' — keeper
    # may prefix auth prompts or diagnostics to stdout when session expires.
    json=$(printf '%s\n' "$raw" | awk '/^[[:space:]]*[\[{]/ {found=1} found {print}')

    if [ -z "$json" ] || ! printf '%s' "$json" | jq empty >/dev/null 2>&1; then
      cat >&2 <<EOF

⚠ Could not parse Keeper output as JSON. Usually this means your Keeper session
  needs to be refreshed. Run this in your terminal, then retry:

      keeper login
      dots keys sync

EOF
      exit 2
    fi

    # Extract (title, password) for records whose title matches the env-var
    # regex and whose password is non-empty. Handles both array-root and
    # object-root top-level shapes.
    pairs=$(printf '%s' "$json" | jq -r --arg re "$TITLE_REGEX" '
      (if type == "array" then . else (.records // []) end)
      | .[]
      | select((.title // "") | test($re))
      | select((.password // "") != "")
      | "\(.title)\t\(.password)"
    ')

    if [ -z "$pairs" ]; then
      echo "No env-var-style records with passwords found in '$ENV_FOLDER'." >&2
      exit 0
    fi

    fetched=0; skipped_dupe=0
    names_tmp=$(mktemp)
    seen_tmp=$(mktemp)
    while IFS=$'\t' read -r title value; do
      [ -z "$title" ] && continue
      if grep -Fxq "$title" "$seen_tmp" 2>/dev/null; then
        echo "⚠ $title: duplicate record in '$ENV_FOLDER' (keeping first)" >&2
        skipped_dupe=$((skipped_dupe+1))
        continue
      fi
      printf '%s\n' "$title" >> "$seen_tmp"
      security add-generic-password -U -s "$title" -a "$USER" -w "$value"
      printf '%s\n' "$title" >> "$names_tmp"
      echo "✓ $title"
      fetched=$((fetched+1))
    done <<< "$pairs"
    rm -f "$seen_tmp"
    mv "$names_tmp" "$NAMES_FILE"
    echo ""
    echo "Synced $fetched to Keychain (skipped $skipped_dupe dupes). One keeper call."
    ;;

  add)
    name="${2:-}"
    if [ -z "$name" ]; then
      echo "usage: keys add <NAME> [VALUE]" >&2
      echo "  VALUE omitted → prompt (recommended; argv leaks to history and ps)" >&2
      exit 1
    fi
    if ! [[ "$name" =~ ^[A-Z][A-Z0-9_]+$ ]]; then
      echo "error: NAME must be UPPER_SNAKE_CASE (e.g. MY_API_TOKEN)" >&2
      exit 1
    fi
    if [ "$#" -ge 3 ]; then
      echo "⚠ passing VALUE on argv leaks the secret to shell history and 'ps'." >&2
      echo "  prefer 'dots keys add $name' to be prompted." >&2
      value="$3"
    else
      read -rs -p "value: " value
      echo
      if [ -z "$value" ]; then
        echo "error: empty value" >&2
        exit 1
      fi
    fi
    keeper record-add -t "$name" --folder "$ENV_FOLDER" -rt login "password=$value"
    "$0" sync
    ;;

  rm)
    name="${2:-}"
    if [ -z "$name" ]; then echo "usage: keys rm <NAME>" >&2; exit 1; fi
    if security delete-generic-password -s "$name" -a "$USER" >/dev/null 2>&1; then
      echo "✓ removed $name from Keychain"
    else
      echo "⚠ $name not in Keychain"
    fi
    if [ -f "$NAMES_FILE" ]; then
      tmp=$(mktemp)
      grep -v "^$name$" "$NAMES_FILE" > "$tmp" || true
      mv "$tmp" "$NAMES_FILE"
    fi
    echo "Note: Keeper record untouched — delete manually in Keeper if desired."
    ;;

  *)
    cat >&2 <<EOF
usage: keys <command>

  add NAME [VALUE]  create a Keeper record and sync it to Keychain
                    (omit VALUE to be prompted; argv leaks to history and ps)
  list            show each env-var in the names list (present|MISSING in Keychain)
  sync            pull every ENV_VAR_STYLE-titled Keeper record into Keychain
  rm NAME         remove from Keychain (Keeper record untouched)

Adding a key: create a record in Keeper with an env-var-style title
(e.g., TODOIST_API_TOKEN) and put the value in the password field.
Then run 'dots keys sync'. No local manifest to edit.
EOF
    exit 1
    ;;
esac

#!/usr/bin/env bash
# Report symlink health + uncommitted drift in the repo.
# --quiet: silent on clean state, one-line summary when dirty.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MANIFEST="$REPO_ROOT/manifest.toml"
QUIET=0
[ "${1:-}" = "--quiet" ] && QUIET=1

parse_manifest() {
  awk '
    /^\[\[link\]\]/ { in_link=1; src=""; dest=""; next }
    in_link && /^src[[:space:]]*=/  { match($0, /"[^"]*"/); src  = substr($0, RSTART+1, RLENGTH-2) }
    in_link && /^dest[[:space:]]*=/ {
      match($0, /"[^"]*"/); dest = substr($0, RSTART+1, RLENGTH-2)
      if (src != "" && dest != "") print src "\t" dest
      in_link=0
    }
  ' "$MANIFEST"
}

expand_home() {
  case "$1" in
    "~/"*) echo "$HOME/${1:2}" ;;
    *)     echo "$1" ;;
  esac
}

ok=0; bad=0
issues=""

EXPECTED_FILE="$(mktemp)"
PARENTS_FILE="$(mktemp)"
trap 'rm -f "$EXPECTED_FILE" "$PARENTS_FILE"' EXIT

while IFS=$'\t' read -r src dest; do
  dest_abs="$(expand_home "$dest")"
  case "$src" in
    "~/"*) expected="$(expand_home "$src")" ;;
    /*)    expected="$src" ;;
    *)     expected="$REPO_ROOT/$src" ;;
  esac
  echo "$dest_abs" >> "$EXPECTED_FILE"
  dirname "$dest_abs" >> "$PARENTS_FILE"
  if [ -L "$dest_abs" ] && [ "$(readlink "$dest_abs")" = "$expected" ]; then
    if [ -e "$dest_abs" ]; then
      ok=$((ok+1))
    else
      bad=$((bad+1)); issues="${issues}  $dest (broken/dangling)"$'\n'
    fi
  else
    bad=$((bad+1))
    if [ ! -e "$dest_abs" ] && [ ! -L "$dest_abs" ]; then
      issues="${issues}  $dest (missing)"$'\n'
    else
      issues="${issues}  $dest (not our symlink)"$'\n'
    fi
  fi
done < <(parse_manifest)

# Detect orphans: symlinks in manifest parent dirs whose target points into
# REPO_ROOT but which are not in the manifest. These are leftover from removed
# entries; running `dots link` will prune them.
orphans=0
orphan_list=""
while IFS= read -r parent; do
  [ -d "$parent" ] || continue
  while IFS= read -r -d '' link; do
    target="$(readlink "$link")"
    case "$target" in
      "$REPO_ROOT"/*)
        if ! grep -Fxq "$link" "$EXPECTED_FILE"; then
          rel="${link#$HOME/}"
          if [ "$rel" != "$link" ]; then
            display="~/$rel"
          else
            display="$link"
          fi
          orphan_list="${orphan_list}  $display"$'\n'
          orphans=$((orphans+1))
        fi
        ;;
    esac
  done < <(find "$parent" -maxdepth 1 -type l -print0 2>/dev/null)
done < <(sort -u "$PARENTS_FILE")

total=$((ok + bad))

cd "$REPO_ROOT"
git_status="$(git status --porcelain 2>/dev/null || true)"
git_count=0
if [ -n "$git_status" ]; then
  git_count=$(printf '%s\n' "$git_status" | wc -l | tr -d ' ')
fi

default_branch="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')"
default_branch="${default_branch:-main}"
ahead=0; behind=0
if git rev-parse "origin/$default_branch" &>/dev/null; then
  ahead=$(git rev-list --count "origin/$default_branch..HEAD" 2>/dev/null || echo 0)
  behind=$(git rev-list --count "HEAD..origin/$default_branch" 2>/dev/null || echo 0)
fi

clean=1
[ "$bad" -gt 0 ]       && clean=0
[ "$orphans" -gt 0 ]   && clean=0
[ "$git_count" -gt 0 ] && clean=0
[ "$ahead" -gt 0 ]     && clean=0
[ "$behind" -gt 0 ]    && clean=0

if [ "$QUIET" = 1 ]; then
  if [ "$clean" = 0 ]; then
    only_unpushed=0
    if [ "$ahead" -gt 0 ] && [ "$bad" -eq 0 ] && [ "$orphans" -eq 0 ] && [ "$git_count" -eq 0 ] && [ "$behind" -eq 0 ]; then
      only_unpushed=1
    fi
    if [ "$only_unpushed" = 1 ]; then
      echo "dotfiles: ${ahead} unpushed commit(s) — run 'dots push' to push"
    else
      parts=""
      [ "$bad" -gt 0 ]       && parts="${parts}${bad} symlink issue(s) "
      [ "$orphans" -gt 0 ]   && parts="${parts}${orphans} orphan symlink(s) "
      [ "$git_count" -gt 0 ] && parts="${parts}${git_count} uncommitted change(s) "
      [ "$ahead" -gt 0 ]     && parts="${parts}${ahead} unpushed commit(s) "
      [ "$behind" -gt 0 ]    && parts="${parts}${behind} commit(s) behind remote "
      echo "dotfiles: ${parts}— run 'dots doctor' for detail"
    fi
    exit 1
  fi
  exit 0
fi

if [ "$bad" -eq 0 ]; then
  echo "✓ $ok/$total symlinks healthy"
else
  echo "✗ $bad/$total symlink issues:"
  printf '%s' "$issues"
fi

if [ "$orphans" -gt 0 ]; then
  echo "✗ $orphans orphan symlink(s) into repo (run: dots link to prune):"
  printf '%s' "$orphan_list"
else
  echo "✓ no orphan symlinks"
fi

if [ "$git_count" -gt 0 ]; then
  echo "✗ $git_count uncommitted changes:"
  printf '%s\n' "$git_status" | sed 's/^/  /'
  git_diff="$(git diff HEAD --color=always 2>/dev/null || true)"
  if [ -n "$git_diff" ]; then
    diff_lines=$(printf '%s\n' "$git_diff" | wc -l | tr -d ' ')
    term_lines=$(tput lines 2>/dev/null || echo 40)
    if [ "$diff_lines" -le "$term_lines" ]; then
      echo ""
      printf '%s\n' "$git_diff"
    fi
  fi
else
  echo "✓ no uncommitted changes"
fi

if [ "$ahead" -gt 0 ]; then
  echo "✗ $ahead unpushed commit(s) ahead of origin/$default_branch (run: dots push):"
  git log --oneline "origin/$default_branch..HEAD" 2>/dev/null | sed 's/^/  /'
else
  echo "✓ in sync with origin/$default_branch"
fi

if [ "$behind" -gt 0 ]; then
  echo "✗ $behind commit(s) behind origin/$default_branch (run: git pull)"
fi

if command -v gitleaks >/dev/null 2>&1; then
  echo "✓ gitleaks installed ($(gitleaks version 2>/dev/null))"
else
  echo "✗ gitleaks not installed (run: bin/bootstrap)"
  clean=0
fi

[ "$clean" = 1 ] && exit 0 || exit 1

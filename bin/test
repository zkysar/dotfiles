#!/usr/bin/env bash
# Run repo self-tests: manifest integrity, shell syntax, secrets scan.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MANIFEST="$REPO_ROOT/manifest.toml"

pass=0; fail=0

ok()   { echo "  ✓ $*"; pass=$((pass+1)); }
fail() { echo "  ✗ $*"; fail=$((fail+1)); }

# ---------------------------------------------------------------------------
# 1. Manifest integrity — every src path must exist in the repo
# ---------------------------------------------------------------------------
echo "1. Manifest integrity"
while IFS= read -r src; do
  case "$src" in
    "~/"*) check_path="${src/#\~/$HOME}" ;;
    /*)    check_path="$src" ;;
    *)     check_path="$REPO_ROOT/$src" ;;
  esac
  if [ -e "$check_path" ]; then
    ok "$src"
  else
    fail "$src (missing from repo or external path)"
  fi
done < <(awk '/^src[[:space:]]*=/ { match($0, /"[^"]*"/); print substr($0, RSTART+1, RLENGTH-2) }' "$MANIFEST")

# ---------------------------------------------------------------------------
# 2. Shell syntax check
# ---------------------------------------------------------------------------
echo "2. Shell syntax"
while IFS= read -r -d '' f; do
  rel="${f#$REPO_ROOT/}"
  if zsh -n "$f" 2>/dev/null; then
    ok "$rel"
  else
    fail "$rel (syntax error)"
  fi
done < <(find "$REPO_ROOT/shell" -type f -print0)

# ---------------------------------------------------------------------------
# 3. Secrets scan (delegated to gitleaks; .gitleaks.toml at repo root tunes it)
# ---------------------------------------------------------------------------
echo "3. Secrets scan"
if ! command -v gitleaks >/dev/null 2>&1; then
  fail "gitleaks not installed — run bin/bootstrap"
elif gl_out=$(gitleaks git --redact --no-banner "$REPO_ROOT" 2>&1); then
  ok "no secrets detected (gitleaks)"
else
  fail "gitleaks found secrets — run \`gitleaks git --redact $REPO_ROOT\` for details"
  printf '%s\n' "$gl_out" | sed 's/^/      /'
fi

# ---------------------------------------------------------------------------
# 4. Backup pruning — bin/_prune-backups removes >30-day-old entries
# ---------------------------------------------------------------------------
echo "4. Backup pruning"
prune_test_root="$(mktemp -d -t dots-prune.XXXXXX)"
mkdir "$prune_test_root/old_entry" "$prune_test_root/recent_entry"
# BSD touch (macOS): -t [[CC]YY]MMDDhhmm sets mtime. 60 days back → >30 days old.
old_stamp="$(date -v-60d +%Y%m%d0000 2>/dev/null || date -d '60 days ago' +%Y%m%d0000)"
touch -t "$old_stamp" "$prune_test_root/old_entry"

prune_out="$("$REPO_ROOT/bin/_prune-backups" "$prune_test_root" 2>&1 || true)"

if [ ! -e "$prune_test_root/old_entry" ] && [ -d "$prune_test_root/recent_entry" ]; then
  ok "old backup pruned, recent backup retained"
else
  fail "prune did not behave as expected (output: $prune_out)"
fi
rm -rf "$prune_test_root"

# Missing backup root must not error
if "$REPO_ROOT/bin/_prune-backups" "/nonexistent/dotfiles-backup-$$" >/dev/null 2>&1; then
  ok "prune handles missing backup root cleanly"
else
  fail "prune errored on missing backup root"
fi

# ---------------------------------------------------------------------------
# 5. requires_local — dots doctor flags a missing untracked companion file
# ---------------------------------------------------------------------------
echo "5. requires_local (doctor)"
rl_tmp="$(mktemp -d -t dots-rl.XXXXXX)"
: > "$rl_tmp/present.local"
cat > "$rl_tmp/manifest.toml" <<EOF
[[link]]
src            = "manifest.toml"
requires_local = "$rl_tmp/missing.local"
dest           = "$rl_tmp/dest_missing"

[[link]]
src            = "manifest.toml"
requires_local = "$rl_tmp/present.local"
dest           = "$rl_tmp/dest_present"
EOF
rl_out="$(MANIFEST="$rl_tmp/manifest.toml" "$REPO_ROOT/bin/doctor" 2>&1 || true)"
if printf '%s' "$rl_out" | grep -qF "$rl_tmp/missing.local"; then
  ok "flags missing required-local companion"
else
  fail "did not flag missing required-local companion"
fi
if printf '%s' "$rl_out" | grep -qF "$rl_tmp/present.local"; then
  fail "incorrectly flagged a present required-local companion"
else
  ok "does not flag present required-local companion"
fi
rm -rf "$rl_tmp"

# ---------------------------------------------------------------------------
# 6. Platform filter — bin/link skips entries whose platform != current OS
# ---------------------------------------------------------------------------
echo "6. Platform filter (bin/link)"
pf_tmp="$(mktemp -d -t dots-pf.XXXXXX)"
: > "$pf_tmp/srcfile"
cat > "$pf_tmp/manifest.toml" <<EOF
[[link]]
src      = "$pf_tmp/srcfile"
platform = "macos"
dest     = "$pf_tmp/dest_macos"

[[link]]
src      = "$pf_tmp/srcfile"
platform = "linux"
dest     = "$pf_tmp/dest_linux"

[[link]]
src  = "$pf_tmp/srcfile"
dest = "$pf_tmp/dest_all"
EOF
HOME="$pf_tmp" MANIFEST="$pf_tmp/manifest.toml" DOTS_PLATFORM=linux \
  "$REPO_ROOT/bin/link" >/dev/null 2>&1 || true
if [ -L "$pf_tmp/dest_linux" ] && [ -L "$pf_tmp/dest_all" ] && [ ! -e "$pf_tmp/dest_macos" ]; then
  ok "linux + all linked, macos skipped (DOTS_PLATFORM=linux)"
else
  fail "platform filter wrong: linux=$([ -L "$pf_tmp/dest_linux" ] && echo L) all=$([ -L "$pf_tmp/dest_all" ] && echo L) macos=$([ -e "$pf_tmp/dest_macos" ] && echo present)"
fi
rm -rf "$pf_tmp"

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
echo ""
total=$((pass+fail))
if [ "$fail" -eq 0 ]; then
  echo "✓ all $total checks passed"
  exit 0
else
  echo "✗ $fail/$total checks failed"
  exit 1
fi

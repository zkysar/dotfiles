#!/usr/bin/env bash
# Push pending commits on the current branch to origin.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
if [ -z "$branch" ]; then
  echo "dots push: not on a branch (detached HEAD)" >&2
  exit 1
fi

default_branch="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')"
default_branch="${default_branch:-main}"

if git rev-parse "origin/$branch" &>/dev/null; then
  ahead=$(git rev-list --count "origin/$branch..HEAD" 2>/dev/null || echo 0)
  if [ "$ahead" = 0 ]; then
    echo "✓ nothing to push (origin/$branch up to date)"
    exit 0
  fi
  echo "→ pushing $ahead commit(s) to origin/$branch"
  exec git push origin "$branch"
fi

echo "→ pushing $branch to origin (new upstream)"
exec git push -u origin "$branch"

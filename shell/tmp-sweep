#!/usr/bin/env bash
# Deletes files in ~/tmp older than 14 days. Skips symlinks.
set -euo pipefail

TMP_DIR="$HOME/tmp"
MAX_AGE_DAYS=14

[ -d "$TMP_DIR" ] || exit 0

find "$TMP_DIR" -mindepth 1 -maxdepth 1 \
  ! -type l \
  ! -name "CLAUDE.md" \
  -mtime +"$MAX_AGE_DAYS" \
  -print \
  -exec rm -rf {} + \
  | awk 'BEGIN { n=0 } { print; n++ } END { print "['"$(date)"'] tmp-sweep complete: " n " item(s) deleted" }'

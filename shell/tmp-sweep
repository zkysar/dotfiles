#!/usr/bin/env bash
# Deletes files in ~/tmp older than 14 days. Skips symlinks.
set -euo pipefail

TMP_DIR="$HOME/tmp"
MAX_AGE_DAYS=14

[ -d "$TMP_DIR" ] || exit 0

find "$TMP_DIR" -maxdepth 1 \
  ! -type l \
  ! -name "CLAUDE.md" \
  -mtime +"$MAX_AGE_DAYS" \
  -exec rm -rf {} + \
  && echo "$(date): tmp-sweep complete"
